{
  "name": "chrono-keep",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify:phase1": "esbuild scripts/verify-phase1.ts --bundle --format=esm --loader:.ogg=empty --loader:.png=empty --outfile=node_modules/.cache/verify-phase1.mjs --log-level=warning && node node_modules/.cache/verify-phase1.mjs",
    "simulate": "esbuild scripts/simulate.ts --bundle --format=esm --loader:.ogg=empty --loader:.png=empty --outfile=node_modules/.cache/simulate.mjs --log-level=warning && node node_modules/.cache/simulate.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
